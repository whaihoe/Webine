# Vercel: Preview and Production. Safe to expose in the browser bundle.
VITE_CLERK_PUBLISHABLE_KEY=

# Vercel: Preview and Production. Server-only except the publishable key.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
ADMIN_USER_ID=
CLERK_AUTHORIZED_PARTIES=https://your-project.vercel.app,https://your-future-domain.com

# Vercel: use separate Preview and Production Turso databases where possible.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel: added automatically after a public Blob store is linked.
BLOB_READ_WRITE_TOKEN=

# Vercel: Preview and Production. Keep all three server-only.
# ENQUIRY_HASH_SECRET is required. The webhook and its token are optional.
ENQUIRY_HASH_SECRET=
ENQUIRY_NOTIFICATION_WEBHOOK_URL=
ENQUIRY_NOTIFICATION_TOKEN=

# Vercel: optional public value displayed on Contact and in the footer.
VITE_PUBLIC_CONTACT_EMAIL=

# Local .env.development only. Never add these to Vercel.
ADMIN_DEV_BYPASS=false
ADMIN_DEV_LABEL=Local Webine owner
