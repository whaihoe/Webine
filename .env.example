# Vercel Preview and Production. This is intentionally public in the browser.
# Use the same Clerk publishable key for both publishable-key variables.
VITE_CLERK_PUBLISHABLE_KEY=

# Vercel Preview and Production. Keep the secret key and owner ID server-only.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
ADMIN_USER_ID=
CLERK_AUTHORIZED_PARTIES=https://your-project.vercel.app,https://your-future-domain.com

# Vercel Preview and Production. Use separate Turso databases or tokens where possible.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel Preview and Production. Connect a Blob store to this project so Vercel creates it.
BLOB_READ_WRITE_TOKEN=

# Vercel Preview and Production. Keep all three server-only.
# ENQUIRY_HASH_SECRET is required and must be at least 32 characters.
# Generate it locally with: openssl rand -hex 32
# The webhook and its token are optional.
ENQUIRY_HASH_SECRET=
ENQUIRY_NOTIFICATION_WEBHOOK_URL=
ENQUIRY_NOTIFICATION_TOKEN=

# Optional public value displayed on Contact and in the footer.
VITE_PUBLIC_CONTACT_EMAIL=

# Local .env.development only. Never add these to Vercel or GitHub.
ADMIN_DEV_BYPASS=false
ADMIN_DEV_LABEL=Local Webine owner

# Optional local backup destination. Never add this to Vercel.
WEBINE_BACKUP_DIRECTORY=
