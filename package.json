{
  "name": "webine-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "minimatch": "9.0.7"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:vercel": "npm run check:production-env && npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "check:production-env": "node scripts/check-production-env.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:backup": "node scripts/backup-local.mjs",
    "db:restore": "node scripts/restore-local.mjs",
    "generate:reach-model": "node scripts/generate-reach-model.mjs",
    "generate:deszio-case-study": "node scripts/generate-deszio-case-study.mjs",
    "publish:deszio": "node scripts/publish-deszio-project.mjs",
    "lint": "eslint src server api dev scripts tests vite.config.ts --ext .ts,.tsx,.mjs --max-warnings 0",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "build:test-server": "tsc -p tsconfig.server-test.json",
    "test": "npm run build && npm run typecheck:server && npm run build:test-server && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.5",
    "@clerk/react": "^6.12.3",
    "@libsql/client": "^0.17.4",
    "@react-three/fiber": "8.18.0",
    "@vercel/blob": "^2.6.1",
    "gsap": "3.15.0",
    "lenis": "^1.3.25",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.4",
    "sharp": "^0.35.3",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "0.185.1",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "8.5.18",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  }
}
