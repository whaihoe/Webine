    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.21",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.3.3",
